# Variables de Entorno - Desarrollo
# Al dejar estas variables vacías o apuntando a "", Axios usará el host actual (ej: http://201.249.162.214:5173).
# Las peticiones a /api serán interceptadas por el proxy de Vite y enviadas al backend en .21:3000 localmente.

# URL base del backend (sin /api)
VITE_API_BASE_URL=

# URL para Socket.io (normalmente la misma que el backend)
# VITE_SOCKET_URL=http://10.60.0.21:3000
VITE_SOCKET_URL=
